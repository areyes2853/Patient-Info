# Development settings
NODE_ENV=development
PORT=3001
HL7_PORT=4000


CORS_ORIGIN=http://localhost:3000

# FHIR Configuration
FHIR_BASE_URL=https://r4.smarthealthit.org
CLIENT_ID=my_medical_app

# DICOM Configuration
DICOM_BASE_URL=https://dicomserver.co.uk:8989

# Database (for when you add MongoDB)
MONGODB_URI=mongodb://localhost:27017/medical_app

# JWT (for when you add auth)
JWT_SECRET=your-super-secret-jwt-key-change-in-production

